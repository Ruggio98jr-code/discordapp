# ============================================
# discord self-bot — configuration
# ============================================
# copy this file as .env and fill in the values

# your discord user token
DISCORD_TOKEN=your_token_here

# source server (guild) ID to monitor
SOURCE_GUILD_ID=your_server_id_here

# channel IDs to EXCLUDE from forwarding (comma-separated)
# leave empty to forward from ALL channels
# example: 123456789,987654321
EXCLUDED_CHANNEL_IDS=

# ─── webhook routing ──────────────────────────────────────

# default webhooks — used for channels without a specific route (comma-separated)
# create multiple webhooks on the same channel for higher throughput
WEBHOOK_URLS=your_webhook_url_1,your_webhook_url_2

# channel-specific routing (optional)
# format: sourceChannelId=webhookUrl1|webhookUrl2;anotherChannelId=webhookUrl3
# this lets you send messages from specific source channels to specific destination channels.
# channels not listed here will use WEBHOOK_URLS above.
# example:
#   CHANNEL_ROUTES=111222333=https://discord.com/api/webhooks/aaa;444555666=https://discord.com/api/webhooks/bbb
CHANNEL_ROUTES=

# ─── options ───────────────────────────────────────────────

# forward message embeds? (true/false)
FORWARD_EMBEDS=true

# forward attachments (images, files)? (true/false)
FORWARD_ATTACHMENTS=true

# ignore messages sent by yourself? (true/false)
IGNORE_SELF=true
